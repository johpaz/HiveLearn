# HiveLearn Environment Variables

# ── Server Configuration ─────────────────────────────────────
HIVELEARN_PORT=8787
HIVELEARN_HOST=0.0.0.0

# ── Database Configuration ────────────────────────────────────
# Opcional: por defecto usa ~/.hivelearn/hivelearn.db
# HIVELEARN_DB_PATH=/path/to/hivelearn.db

# ── LLM Provider Configuration ────────────────────────────────
# Opcional: se puede configurar vía API /api/hivelearn/config
# HIVELEARN_PROVIDER=ollama
# HIVELEARN_MODEL=gemma4-e4b

# ── API Keys (si se usan providers cloud) ─────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# ── Development ───────────────────────────────────────────────
# NODE_ENV=development
