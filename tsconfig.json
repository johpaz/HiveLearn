{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "paths": {
      "@johpaz/hivelearn-core": ["./packages/core/src/index.ts"],
      "@johpaz/hivelearn-core/*": ["./packages/core/src/*"],
      "@johpaz/hivelearn-ui": ["./packages/ui/src/index.ts"],
      "@johpaz/hivelearn-ui/*": ["./packages/ui/src/*"],
      "@johpaz/hivelearn-cli": ["./packages/cli/src/index.ts"],
      "@johpaz/hivelearn-cli/*": ["./packages/cli/src/*"],
      "@johpaz/hivelearn-tts": ["./packages/tts/src/index.ts"],
      "@johpaz/hivelearn-tts/*": ["./packages/tts/src/*"]
    }
  },
  "files": [],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/ui" },
    { "path": "./packages/cli" },
    { "path": "./packages/tts" }
  ]
}