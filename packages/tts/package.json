{
  "name": "@johpaz/hivelearn-tts",
  "version": "0.1.0",
  "description": "Offline local TTS for HiveLearn — Piper-based fallback when no internet providers available",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "postinstall": "bun run src/install.ts",
    "start": "bun run src/server.ts",
    "dev": "bun --watch src/server.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": ["hivelearn", "tts", "offline", "piper", "voice", "spanish"],
  "license": "MIT"
}
