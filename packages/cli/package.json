{
  "name": "@johpaz/hivelearn-cli",
  "version": "0.1.0",
  "description": "HiveLearn CLI — Command line interface for the HiveLearn AI Gateway",
  "type": "module",
  "bin": {
    "hivelearn": "./dist/hive.js",
    "hive": "./dist/hive.js"
  },
  "main": "./dist/hive.js",
  "license": "MIT",
  "files": [
    "dist/hive.js",
    "dist/hive.cmd",
    "dist/hive.ps1",
    "README.md"
  ],
  "scripts": {
    "build": "bun run scripts/generate-ui-bundle.ts && bun build src/index.ts --outfile dist/hive.js --target bun && bun run scripts/postbuild.ts",
    "postbuild": "bun run scripts/postbuild.ts",
    "dev": "bun run src/index.ts start",
    "dev:watch": "bun --watch src/index.ts start",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "@johpaz/hivelearn-core": "workspace:*",
    "toon-format-parser": "1.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "6.0.3"
  }
}